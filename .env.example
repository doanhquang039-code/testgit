# Copy to .env and adjust values for local Docker usage.

# MySQL (docker-compose)
MYSQL_DATABASE=hr_management_system
MYSQL_USER=hr_user
MYSQL_PASSWORD=hr_password
MYSQL_ROOT_PASSWORD=root

# App secrets (optional)
DB_USERNAME=
DB_PASSWORD=
AUDIT_ENCRYPTION_KEY=change-this-to-a-long-random-secret

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

MAIL_USERNAME=
MAIL_PASSWORD=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# AI / Gemini
# Enable only when you have a valid API key.
AI_GEMINI_ENABLED=false
GEMINI_API_KEY=
AI_GEMINI_MODEL=gemini-1.5-flash

